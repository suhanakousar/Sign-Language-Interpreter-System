# Application
NODE_ENV=development
PORT=3001

# Frontend
NEXT_PUBLIC_WS_URL=ws://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Python Services
SPEECH_TO_TEXT_URL=http://localhost:8001
NLP_PROCESSOR_URL=http://localhost:8002
TEXT_TO_SIGN_URL=http://localhost:8003

# Database
MONGODB_URI=mongodb://localhost:27017/sign-language-interpreter
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRY=24h

# Whisper
WHISPER_MODEL=base
WHISPER_DEVICE=cpu

# Logging
LOG_LEVEL=info
